# Postgres credentials for local docker-compose.
# Copy to .env (which is git-ignored) and edit if needed.

POSTGRES_USER=crawler
POSTGRES_PASSWORD=crawler
POSTGRES_DB=crawler
POSTGRES_PORT=5432

# DSN consumed by crawler.storage.Database.
# Hostname `localhost` works when running Python on the host while Postgres
# runs inside docker-compose with port-forwarding (POSTGRES_PORT above).
CRAWLER_DATABASE_DSN=postgresql://crawler:crawler@localhost:5432/crawler
